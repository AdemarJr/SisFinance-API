# Porta (Railway injeta automaticamente em produção)
PORT=3001

# Ambiente
NODE_ENV=development

# Segredo dos tokens JWT da API
JWT_SECRET=troque-por-um-segredo-forte

# Supabase (apenas Postgres + Auth admin)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Não usar no Railway (somente dev local, se quiser servir o frontend)
# SERVE_STATIC=false
