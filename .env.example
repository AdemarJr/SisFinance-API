# =============================================================================
# SisFinance API — variáveis de ambiente
# =============================================================================
# Copie para .env (local) ou configure no Railway → Variables
# =============================================================================

NODE_ENV=production
PORT=3001

# JWT da API (tokens emitidos no login)
JWT_SECRET=troque-por-um-segredo-longo-aleatorio

# -----------------------------------------------------------------------------
# Opção A — Postgres direto (Easypanel / Railway Postgres)
# Quando DATABASE_URL está definida, Supabase NÃO é necessário.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=disable

# Alternativa (Railway monta DATABASE_URL automaticamente a partir destas):
# PGHOST=easypanel.pyrou.com.br
# PGPORT=5432
# PGDATABASE=pyrou-finace
# PGUSER=pyrouwebdb
# PGPASSWORD=sua-senha

# -----------------------------------------------------------------------------
# Opção B — Supabase (legado: PostgREST + Auth)
# Use apenas se NÃO estiver usando DATABASE_URL.
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://SEU_PROJETO.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# Admin inicial (script npm run set-admin-password)
# ADMIN_EMAIL=admin@sisfinance.com
# ADMIN_PASSWORD=Admin@123456
