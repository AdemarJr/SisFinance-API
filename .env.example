# =============================================================================
# SisFinance API — variáveis de ambiente
# =============================================================================

NODE_ENV=production
PORT=3001
JWT_SECRET=troque-por-um-segredo-longo-aleatorio

# -----------------------------------------------------------------------------
# Postgres Easypanel — PREFERIR estas variáveis (senha com @ * ! sem encode)
# -----------------------------------------------------------------------------
PGHOST=easypanel.pyrou.com.br
PGPORT=5432
PGDATABASE=pyrou-finace
PGUSER=pyrouwebdb
PGPASSWORD=sua-senha-literal
PGSSLMODE=disable

# Alternativa (só se a senha estiver URL-encoded: @=%40  *=%2A)
# DATABASE_URL=postgresql://pyrouwebdb:SENHA_ENCODED@easypanel.pyrou.com.br:5432/pyrou-finace?sslmode=disable

# Admin (npm run set-admin-password)
# ADMIN_EMAIL=admin@sisfinance.com
# ADMIN_PASSWORD=Admin@123456
